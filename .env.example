# Copy this file to ".env" next to docker-compose.yml ON THE SERVER
# (/srv/chhindustry-web/.env). docker compose reads it automatically and
# injects the values into the containers.
#
# Do NOT commit the real .env — it is gitignored.

# --- LINE (contact form -> LINE group) ---
# LINE Messaging API channel access token (long-lived)
LINE_CHANNEL_ACCESS_TOKEN=

# Target LINE group ID that receives contact / factory-visit notifications
LINE_GROUP_ID=

# --- PocketBase first admin (back-office) ---
# Used ONLY on the very first deploy to seed the first admin account.
# After the first run you can manage admins from the website back-office,
# so these can be left in place or cleared. Use a strong password.
INITIAL_ADMIN_EMAIL=admin@chhindustry.com
INITIAL_ADMIN_PASSWORD=
